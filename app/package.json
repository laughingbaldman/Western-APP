{
  "name": "western-intelligence-support-agent",
  "version": "1.0.0",
  "description": "Western Building Supply - Paradigm ERP Support Agent powered by LM Studio RAG",
  "main": "src/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "start:system-ca": "set NODE_OPTIONS=--use-system-ca&& electron .",
    "dev": "electron . --development",
    "dev:system-ca": "set NODE_OPTIONS=--use-system-ca&& electron . --development",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:coverage": "c8 --reporter=text --reporter=lcov npm run test",
    "build": "electron-builder",
    "build:signed": "electron-builder --config electron-builder-signed.json",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "patch-package"
  },
  "author": "Western Building Supply",
  "license": "Proprietary",
  "dependencies": {
    "axios": "^1.13.5",
    "cheerio": "^1.2.0",
    "csv-parse": "^6.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "ldapts": "^8.1.6",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "ajv-formats": "^3.0.1",
    "c8": "^10.1.3",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "patch-package": "^8.0.1"
  },
  "overrides": {
    "@xmldom/xmldom": "0.9.9",
    "@isaacs/brace-expansion": "5.0.5",
    "ajv": "8.18.0",
    "ajv-keywords": "5.1.0",
    "brace-expansion": "5.0.5",
    "lodash": "4.18.1",
    "minimatch": "10.2.4",
    "picomatch": "4.0.4",
    "socket.io-parser": "4.2.6",
    "tar": "7.5.13",
    "undici": "7.24.0",
    "underscore": "1.13.8",
    "yaml": "2.8.3"
  },
  "build": {
    "appId": "com.western.intelligence",
    "productName": "Western Intelligence",
    "directories": {
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "build/prereqs",
        "to": "prereqs",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "include": null,
      "script": null
    }
  }
}
